# Normaliza line endings para LF em todos os arquivos de texto
* text=auto eol=lf

# Arquivos críticos — forçar LF explicitamente
*.json        text eol=lf
*.ts          text eol=lf
*.tsx         text eol=lf
*.js          text eol=lf
*.jsx         text eol=lf
*.css         text eol=lf
*.md          text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.env*        text eol=lf
*.sh          text eol=lf

# Binários — nunca modificar
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.svg         binary
*.ico         binary
*.woff        binary
*.woff2       binary
*.ttf         binary
*.eot         binary
*.pdf         binary
*.xlsx        binary
*.zip         binary
